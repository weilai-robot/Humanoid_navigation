<mujoco model="car nav scene">
  <!--
    小车 MuJoCo 仿真场景  (参考幻尔科技麦粒轮小车)
    车体: 280mm(L) × 200mm(W) × 100mm(H)
    麦轮: 直径100mm (radius=0.050m), 宽40mm
    车体中心高度: wheel_radius + body_half_height = 0.05 + 0.05 = 0.10m
    mid360 雷达: 正装 (Z朝上, identity)，安装高度 0.20m (车体中心 0.10m + 相对偏移 0.10m)
    IMU: 与雷达同位置，extrinsic_T=[0,0,0]
    车体点云由 FAST_LIO2 blind=0.3m 过滤 (真实环境同理)
  -->

  <!-- 引入实验室环境 (墙体/家具/灯光) -->
  <include file="../../robots/x1/mjcf/environment/lab_env.xml"/>

  <option timestep="0.001" integrator="Euler"/>

  <worldbody>
    <!-- ====================================================
         小车主体 (freejoint 提供 6-DOF，由 car_nav.py 按需锁定)
    ==================================================== -->
    <body name="car" pos="0 0 0.10">
      <freejoint name="car_base"/>

      <!-- 车体: 280mm × 200mm × 100mm -->
      <geom name="car_body" type="box" size="0.14 0.10 0.05"
            rgba="0.20 0.45 0.80 1" condim="6" friction="0.8 0.02 0.001"/>

      <!-- 前向指示块 (橙色), 用于在 viewer 中判断朝向 -->
      <geom name="car_front" type="box" size="0.015 0.07 0.03"
            pos="0.145 0 0" rgba="1.0 0.50 0.10 1" condim="1"/>

      <!-- 麦粒轮 × 4: radius=0.050m, width=40mm
           body 底面 z=-0.05, 轮中心 z=-0.05 → 绝对 z=0.05m, 底部 z=0 (贴地) -->
      <!-- 左前轮 (FL) -->
      <geom name="wheel_fl" type="cylinder"
            fromto="0.10 0.10 -0.05  0.10 0.14 -0.05"
            size="0.050" rgba="0.15 0.15 0.15 1" condim="1"/>
      <!-- 右前轮 (FR) -->
      <geom name="wheel_fr" type="cylinder"
            fromto="0.10 -0.10 -0.05  0.10 -0.14 -0.05"
            size="0.050" rgba="0.15 0.15 0.15 1" condim="1"/>
      <!-- 左后轮 (RL) -->
      <geom name="wheel_rl" type="cylinder"
            fromto="-0.10 0.10 -0.05  -0.10 0.14 -0.05"
            size="0.050" rgba="0.15 0.15 0.15 1" condim="1"/>
      <!-- 右后轮 (RR) -->
      <geom name="wheel_rr" type="cylinder"
            fromto="-0.10 -0.10 -0.05  -0.10 -0.14 -0.05"
            size="0.050" rgba="0.15 0.15 0.15 1" condim="1"/>

      <!-- LiDAR site: 正装 (无旋转, Z朝上与车体同向)
           body 中心 z=0.10m, 偏移 +0.10m → 绝对高度 0.20m -->
      <site name="lidar_site" pos="0 0 0.10" size="0.025" rgba="1.0 0.2 0.2 0.9"/>

      <!-- IMU site: 与 lidar_site 同位置 (extrinsic_T=[0,0,0]) -->
      <site name="lidar_imu"  pos="0 0 0.10" size="0.015" rgba="0.2 1.0 0.2 0.9"/>
    </body>
  </worldbody>

  <sensor>
    <!-- IMU 传感器 (与 sim2sim_nav.py 同名，car_nav.py 直接复用) -->
    <framequat     name="lidar-orientation"          objtype="site" objname="lidar_imu"/>
    <gyro          name="lidar-angular-velocity"     site="lidar_imu" noise="0.001"/>
    <accelerometer name="lidar-linear-acceleration"  site="lidar_imu" noise="0.01"/>
  </sensor>

</mujoco>
