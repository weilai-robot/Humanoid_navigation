<mujoco model="nav_room">
  <statistic center="0 0 0.8" extent="6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
  </visual>

  <asset>
    <texture name="skybox" type="skybox" builtin="gradient" rgb1="0.2 0.3 0.4" rgb2="0 0 0" width="800" height="800"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.25 0.35 0.45" rgb2="0.15 0.25 0.35" markrgb="0.8 0.8 0.8"
             width="512" height="512"/>
    <texture type="2d" name="wall_tex" builtin="flat" rgb1="0.7 0.65 0.6" width="64" height="64"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="4 4" reflectance="0.1"/>
    <material name="wall" texture="wall_tex" reflectance="0.05"/>
  </asset>

  <worldbody>
    <light pos="0 0 6" dir="0 0 -1" directional="true" diffuse="0.8 0.8 0.8"/>
    <light pos="3 3 4"  dir="-1 -1 -1" diffuse="0.4 0.4 0.4"/>

    <!-- 地面 -->
    <geom name="floor" type="plane" size="10 10 0.1"
          material="groundplane" conaffinity="7" condim="3" friction="1"/>

    <!-- ===== 房间外墙 (8m x 8m, 高2.5m) ===== -->
    <!-- 南墙 (x = -4) -->
    <geom name="wall_south" type="box" size="0.1 4 1.25"
          pos="-4 0 1.25" material="wall" conaffinity="7"/>
    <!-- 北墙 (x = +4) -->
    <geom name="wall_north" type="box" size="0.1 4 1.25"
          pos="4 0 1.25" material="wall" conaffinity="7"/>
    <!-- 西墙 (y = -4) -->
    <geom name="wall_west" type="box" size="4 0.1 1.25"
          pos="0 -4 1.25" material="wall" conaffinity="7"/>
    <!-- 东墙 (y = +4) -->
    <geom name="wall_east" type="box" size="4 0.1 1.25"
          pos="0 4 1.25" material="wall" conaffinity="7"/>

    <!-- ===== 内部障碍物（模拟走廊/隔断） ===== -->
    <!-- 中间隔墙（留缺口构成走廊） -->
    <geom name="inner_wall1" type="box" size="0.1 1.5 1.0"
          pos="0 -2.5 1.0" material="wall" conaffinity="7"/>
    <geom name="inner_wall2" type="box" size="0.1 1.5 1.0"
          pos="0 2.5 1.0" material="wall" conaffinity="7"/>

    <!-- 柱子 -->
    <geom name="pillar1" type="cylinder" size="0.15 1.25"
          pos="2 2 1.25" material="wall" conaffinity="7"/>
    <geom name="pillar2" type="cylinder" size="0.15 1.25"
          pos="2 -2 1.25" material="wall" conaffinity="7"/>
    <geom name="pillar3" type="cylinder" size="0.15 1.25"
          pos="-2 2 1.25" material="wall" conaffinity="7"/>
    <geom name="pillar4" type="cylinder" size="0.15 1.25"
          pos="-2 -2 1.25" material="wall" conaffinity="7"/>

    <!-- 天花板 (Z=2.5m，为 LiDAR 提供 Z 轴约束) -->
    <geom name="ceiling" type="box" size="4 4 0.05"
          pos="0 0 2.55" material="wall" conaffinity="0"/>

    <!-- 箱子障碍物 -->
    <geom name="box1" type="box" size="0.3 0.3 0.4"
          pos="1 0 0.4" material="wall" conaffinity="7"/>
    <geom name="box2" type="box" size="0.2 0.4 0.3"
          pos="-1 1.5 0.3" material="wall" conaffinity="7"/>
  </worldbody>
</mujoco>
