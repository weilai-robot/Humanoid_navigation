<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="f1_humanoid">
    <xacro:include filename="$(find ros2_livox_simulation)/urdf/mid360.xacro" />

    <xacro:macro name="cylinder_inertia" params="m r h">
        <inertial>
            <mass value="${m}"/>
            <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
                     iyy="${m*(3*r*r+h*h)/12}" iyz="0"
                     izz="${m*r*r/2}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="my_box_inertia" params="m x y z">
        <inertial>
            <mass value="${m}"/>
            <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
                     iyy="${m*(x*x+z*z)/12}" iyz="0"
                     izz="${m*(x*x+y*y)/12}" />
        </inertial>
    </xacro:macro>

    <link name="base_footprint"/>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.65" rpy="0 0 0"/> 
    </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <cylinder length="1.2" radius="0.15"/>
            </geometry>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <material name="white">
                 <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder length="1.2" radius="0.15"/>
            </geometry>
            <origin rpy="0 0 0" xyz="0 0 0"/>
        </collision>
        <xacro:cylinder_inertia m="15.0" r="0.15" h="1.2"/>
    </link>

    <!-- <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.1"/>
            </geometry>
            <material name="black">
                <color rgba="0 0 0 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.1"/>
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.2" r="0.05" h="0.1"/>
    </link>

    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.66" rpy="0 0 0"/>
    </joint> -->

    <link name="imu_link">
        <visual>
            <geometry>
                <box size="0.05 0.05 0.02"/>
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1"/>
            </material>
        </visual>
        <xacro:my_box_inertia m="0.1" x="0.05" y="0.05" z="0.02"/>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <!-- <origin xyz="0.1 0 0" rpy="0 0 0"/> -->
        <origin xyz="0 0 0.66" rpy="0 0 0"/>
    </joint>

    <gazebo reference="base_link">
        <material>Gazebo/White</material>
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
    </gazebo>
    
    <!-- 用 xacro 宏配置mid360 -->
    <xacro:mid360 name="lidar_link" parent="base_link" topic="/livox/lidar">
        <origin xyz="0 0 0.66" rpy="${M_PI} 0 0" />
    </xacro:mid360>

    <gazebo reference="imu_link">
        <gravity>true</gravity>
        <sensor name="imu_sensor" type="imu">
            <always_on>true</always_on>
            <update_rate>200</update_rate>
            <visualize>true</visualize>

            <imu>
                <angular_velocity>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></z>
                </linear_acceleration>
            </imu>

            <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
                <ros>
                    <namespace>/</namespace>
                    <remapping>~/out:=imu/data</remapping>
                </ros>
                <frame_name>imu_link</frame_name>
                <initial_orientation_as_reference>false</initial_orientation_as_reference>
            </plugin>
        </sensor>
    </gazebo>

    <gazebo>
        <plugin name="object_controller" filename="libgazebo_ros_planar_move.so">
            <commandTopic>cmd_vel</commandTopic>
            <odometryTopic>odom</odometryTopic>
            <odometryFrame>odom</odometryFrame>
            <!-- <odometryTopic>odom_ground_truth</odometryTopic> -->
            <!-- <odometryFrame>odom_gazebo_hidden</odometryFrame> -->
            <odometryRate>20.0</odometryRate>
            <robotBaseFrame>base_footprint</robotBaseFrame>
            <publish_odom_tf>false</publish_odom_tf>
            <!-- <robotBaseFrame>base_footprint_hidden</robotBaseFrame> -->
            <!-- <odometry_topic>odom</odometry_topic>
            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>base_footprint</robot_base_frame>
            <update_rate>20.0</update_rate>
            <publish_odom_tf>true</publish_odom_tf> -->
        </plugin>
    </gazebo>

</robot>